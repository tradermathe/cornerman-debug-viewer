{
  "hosting": {
    "site": "corner-man-dashboard",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      { "source": "**/*.@(js|css|json|html)", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "**/*.mp4", "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }] }
    ]
  }
}
